{
  "name": "eigalang",
  "displayName": "EigaLang",
  "description": "EigaLang Syntax highlight for VScode.",
  "author": {
    "name": "Midry",
    "url": "https://tmidry.com/"
  },
  "license": "MIT",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "eiga",
        "aliases": [
          "EigaLang",
          "eiga",
          "EigaMacro"
        ],
        "extensions": [
          ".eiga",
          ".eigam"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "eiga",
        "scopeName": "source.eiga",
        "path": "./syntaxes/eiga.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/midry3/eiga-vscode"
  },
  "activationEvents": [
    "onLanguage:eiga"
  ]
}
